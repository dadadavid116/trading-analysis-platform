# ─────────────────────────────────────────────────────────────
# .env.example — Environment variable template
#
# Copy this file to .env and fill in your values.
# Never commit the real .env file (it is in .gitignore).
# Never include .env, node_modules, or .claude/ in review bundles.
# If you accidentally expose a secret, rotate it immediately.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trading_db

# Full async connection URL used by the FastAPI backend.
# "db" is the Docker Compose service name for PostgreSQL.
# For local development outside Docker, change "db" to "localhost".
DATABASE_URL=postgresql+asyncpg://trading:changeme@db:5432/trading_db

# ── API server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend (Vite dev server proxy) ──────────────────────────
# Tells the Vite proxy where to forward /api requests.
# Keep this value when running with Docker Compose (service name = "api").
# Change to http://localhost:8000 if running Vite outside Docker.
VITE_API_TARGET=http://api:8000

# ── Exchange / data collection ────────────────────────────────
# Binance public WebSocket — no API key required for market data
EXCHANGE=binance
SYMBOL=BTCUSDT

# ── Claude API (analysis worker) ─────────────────────────────
# Required for the analysis service to generate market summaries.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# How often the analysis worker generates a new summary (in minutes).
# Default is 10 minutes. Increase to reduce API usage.
ANALYSIS_INTERVAL_MINUTES=10

# ── Alerts ────────────────────────────────────────────────────
# How often the alert evaluator checks conditions (in minutes).
# Default is 1 minute.
ALERT_EVALUATION_INTERVAL_MINUTES=1

# ── Telegram bot ──────────────────────────────────────────────
# Required for the Telegram bot service and alert notifications via Telegram.
# Leave blank to disable Telegram features (alerts still log to stdout).
#
# TELEGRAM_BOT_TOKEN — get from @BotFather on Telegram
# TELEGRAM_CHAT_ID   — your personal chat ID or group ID
#   To find your chat ID: message @userinfobot on Telegram
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins for the API.
# For local dev: keep the defaults.
# For production: set to your domain, e.g.:
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ── Dashboard access control — Caddy Basic Auth (REQUIRED for VPS) ────────────
# HTTP Basic Authentication is enforced by Caddy before any request reaches
# the application. This protects both the frontend and the API without
# embedding any secret in the browser bundle.
#
# CADDY_USER            — username shown in the browser login prompt
# CADDY_HASHED_PASSWORD — bcrypt hash of your password (Caddy format)
#
# Generate a hash on the VPS or in Docker:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
#
# The /health endpoint is exempt from auth (uptime monitoring).
# Leave blank for local development (Caddy is not used in docker-compose.yml).
CADDY_USER=
CADDY_HASHED_PASSWORD=

# ── Backend API key — optional secondary defence layer ────────────────────────
# When set, FastAPI also validates X-API-Key on all /api/* requests.
# This is not required — Caddy Basic Auth is the primary gate.
# Not sent by the frontend. Useful for direct API access from trusted scripts.
# Leave blank (default) to rely on Caddy auth only.
DASHBOARD_API_KEY=

# ── Production deployment ──────────────────────────────────────
# Your domain name for Caddy HTTPS (Let's Encrypt).
# Only needed when using docker-compose.prod.yml on a VPS.
# Remove or leave blank for local dev.
DOMAIN=yourdomain.com
