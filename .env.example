# ─────────────────────────────────────────────────────────────
# .env.example — Environment variable template
#
# Copy this file to .env and fill in your values.
# Never commit the real .env file (it is in .gitignore).
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trading_db

# Full async connection URL used by the FastAPI backend.
# "db" is the Docker Compose service name for PostgreSQL.
# For local development outside Docker, change "db" to "localhost".
DATABASE_URL=postgresql+asyncpg://trading:changeme@db:5432/trading_db

# ── API server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend (Vite dev server proxy) ──────────────────────────
# Tells the Vite proxy where to forward /api requests.
# Keep this value when running with Docker Compose (service name = "api").
# Change to http://localhost:8000 if running Vite outside Docker.
VITE_API_TARGET=http://api:8000

# ── Exchange / data collection ────────────────────────────────
# Binance public WebSocket — no API key required for market data
EXCHANGE=binance
SYMBOL=BTCUSDT

# ── Claude API (analysis panel) — used in a later phase ───────
ANTHROPIC_API_KEY=

# ── Alerts (Telegram) — used in a later phase ─────────────────
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
